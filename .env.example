###############################################################################
# StarsPay — пример .env
#
# Скопируйте этот файл в .env и заполните значения. В Dokploy переменные
# вписываются в интерфейсе сервиса (раздел "Environment"), а сам файл
# .env в репозиторий коммитить НЕ нужно (он уже в .gitignore).
#
# Где что взять — описано рядом с каждой переменной.
###############################################################################


# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# Прод (Dokploy):
#   Создайте отдельный сервис Database → PostgreSQL в том же проекте Dokploy,
#   скопируйте "Internal Connection URL" и добавьте к нему `?schema=public`.
#   Пример: postgresql://starspay:<password>@<internal-host>:5432/starspay?schema=public
#
# Локально (`npm run dev:api` + docker-compose.dev.yml):
#   postgresql://starspay:starspay_local_dev_password@localhost:5433/starspay?schema=public
DATABASE_URL=

# Локальная dev-БД (используется только docker-compose.dev.yml).
# В проде эти переменные не нужны — БД отдельным сервисом в Dokploy.
POSTGRES_DB=starspay
POSTGRES_USER=starspay
POSTGRES_PASSWORD=starspay_local_dev_password


# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────────────────────────────

# Токен бота. Получите у @BotFather: /newbot → скопируйте строку вида
# 1234567890:AABBccDDeeFFggHHiiJJkkLLmm. Этим же ботом авторизуем юзеров и
# скачиваем аватарки через Bot API.
TELEGRAM_BOT_TOKEN=

# Срок жизни initData (в секундах). 86400 = 24 часа. Меньше = безопаснее, но
# чаще будут "истёкшие" сессии при долго открытом приложении.
TELEGRAM_AUTH_TTL=86400

# Юзернейм бота БЕЗ символа @. Нужен для построения реферальных ссылок.
# Узнать: @BotFather → /mybots → выбрать бота → видно "Username: @starspay_bot"
# Сюда вписать: starspay_bot
TELEGRAM_BOT_USERNAME=

# Короткое имя Mini App, заданное в BotFather через /newapp (Short name).
# Если бот открывается напрямую через кнопку Web App без short-name —
# можно оставить пустым (тогда реф-ссылки будут вида https://t.me/<bot>?start=<code>).
# С указанным именем ссылка получается deep-link в Mini App:
#   https://t.me/<bot>/<short-name>?startapp=<code>
TELEGRAM_MINIAPP_NAME=

# ─── Telegram Bot webhook (реакция на /start) ────────────────────────────────
# Секрет, которым Telegram подписывает запросы к нашему /api/telegram/webhook.
# Сгенерировать: `openssl rand -hex 32`. Без него endpoint не работает.
TELEGRAM_WEBHOOK_SECRET=

# Полный публичный webhook URL. Обычно оставьте пустым: API сам соберёт
# https://<TELEGRAM_WEBAPP_URL>/api/telegram/webhook и зарегистрирует его в Telegram.
# Заполняйте только если API живёт на другом домене.
TELEGRAM_WEBHOOK_URL=

# Публичный URL вашего Mini App, например https://stars.example.com
# Кнопка "Open StarsPay" в ответе бота будет открывать этот URL как Web App.
TELEGRAM_WEBAPP_URL=

# URL приветственной картинки (любой публичный image-URL).
# Если пусто — бот отправит только текст без фото.
WELCOME_IMAGE_URL=

# ─── Канал заказов для админов ──────────────────────────────────────────────
# ID канала (или supergroup), куда бот пушит каждый новый заказ
# с inline-кнопками для смены статуса. Бот должен быть админом канала.
# Получить id: добавьте бота в канал, отправьте сообщение, дёрните /getUpdates
# или используйте @userinfobot в самом канале.
TELEGRAM_ORDER_CHANNEL=

# Таймаут внешних http-запросов (Bot API, Buypin) в мс.
TELEGRAM_API_TIMEOUT_MS=10000

# ─── Buypin lookup API (имя/премиум по @username) ──────────────────────────
EXTERNAL_API_BASE_URL=https://buypin.net/api/v1
EXTERNAL_API_KEY=
# Game-ключ Buypin для валидации Telegram-юзера (имя/аватарка).
# По умолчанию 'telegram-stars'.
BUYPIN_GAME_KEY=telegram-stars

# Game-ключ для проверки активной Telegram Premium подписки.
# Buypin отвечает 200 если у юзера активный Premium, 422 если нет.
# По умолчанию 'telegram-premium'.
BUYPIN_PREMIUM_GAME_KEY=telegram-premium

# ─── S3 (Yandex Cloud Object Storage) — для чеков ─────────────────────────
AWS_REGION=ru-central1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=https://storage.yandexcloud.net
AWS_S3_FORCE_PATH_STYLE=true
# Публичный префикс — обычно AWS_S3_ENDPOINT/AWS_S3_BUCKET
AWS_S3_PUBLIC_BASE=


# ─────────────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────────────

# Секрет для подписи JWT-сессий. Минимум 32 символа.
# Сгенерировать: `openssl rand -base64 48`
JWT_SECRET=change_me_to_a_random_string_of_at_least_32_chars_aaaaaaaa

# Срок жизни JWT. Поддерживается формат ms-библиотеки: 30m, 24h, 7d, 30d.
JWT_EXPIRES_IN=7d


# ─────────────────────────────────────────────────────────────────────────────
# CORS / домены
# ─────────────────────────────────────────────────────────────────────────────

# Разрешённые origin через запятую. Для прод-режима укажите ваш домен,
# например: https://stars.example.com
# Если фронт и бэк на одном домене (как в этом docker-compose через nginx),
# можно оставить * — реальный CORS не используется, фронт ходит same-origin.
CORS_ORIGINS=*

# Базовый URL API для фронта (передаётся как build-arg в Vite).
# ОСТАВЬТЕ ПУСТЫМ — тогда фронт будет ходить на same-origin через nginx-прокси.
# Заполнять стоит только если фронт и API живут на разных доменах.
VITE_API_BASE=


# ─────────────────────────────────────────────────────────────────────────────
# Логи
# ─────────────────────────────────────────────────────────────────────────────

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
